# Contact form (Part 4) — copy to .env.local and fill in. Never commit real keys.
# The form returns a clear error until RESEND_API_KEY is set.

# Resend API key (https://resend.com) — the only secret. Destination + sender are
# hardcoded in src/app/api/contact/route.ts (public, identical across all demos).
RESEND_API_KEY=

# Optional analytics measurement ID (GA4 / Plausible) — Part 5. Leave blank until supplied.
NEXT_PUBLIC_ANALYTICS_ID=
