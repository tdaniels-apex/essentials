# Contact form (Part 4) — copy to .env.local and fill in. Never commit real keys.
# Travis provides these values; the form returns a clear error until they're set.

# Resend API key (https://resend.com)
RESEND_API_KEY=

# Inbox that receives contact-form applications
CONTACT_TO_EMAIL=

# Verified Resend sender on a domain Travis controls, e.g. notifications@mail.apex-aesthetics.co
CONTACT_FROM_EMAIL=

# Optional analytics measurement ID (GA4 / Plausible) — Part 5. Leave blank until supplied.
NEXT_PUBLIC_ANALYTICS_ID=
